# ================================================================
#  RadiusX Backend -- .env
#  Place this file at:  RADIUS X/backend/.env
#  NEVER commit this file to Git -- it's already in .gitignore
# ================================================================


# ----------------------------------------------------------------
#  MongoDB Atlas
#  Steps:
#  1. Go to https://atlas.mongodb.com
#  2. Create a free M0 cluster
#  3. Database Access -> Add user (username + password)
#  4. Network Access -> Add IP -> Allow from anywhere (0.0.0.0/0)
#  5. Clusters -> Connect -> Drivers -> copy the URI
#  6. Replace <user>, <password>, and keep the /radiusx DB name
# ----------------------------------------------------------------
MONGO_URI=


# ----------------------------------------------------------------
#  JWT Secrets
#  Generate strong secrets -- run this in your terminal:
#  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#  Run it TWICE -- one for access, one for refresh
# ----------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d


# ----------------------------------------------------------------
#  Redis (Upstash -- free tier)
#  Steps:
#  1. Go to https://upstash.com
#  2. Create Account -> Create Database
#  3. Choose region closest to your Railway region
#  4. Click the database -> Details tab
#  5. Copy the "Redis URL" (starts with redis://)
# ----------------------------------------------------------------
REDIS_URL=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=


PORT=5000
NODE_ENV=production

CLIENT_URL=https://goldy2307.github.io/RadiusX/


ADMIN_EMAIL=admin@radiusx.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=RadiusX Admin
