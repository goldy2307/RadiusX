# ----------------------------------------------------------------
#  MongoDB Atlas
#  Steps:
#  1. Go to https://atlas.mongodb.com
#  2. Create a free M0 cluster
#  3. Database Access -> Add user (username + password)
#  4. Network Access -> Add IP -> Allow from anywhere (0.0.0.0/0)
#  5. Clusters -> Connect -> Drivers -> copy the URI
#  6. Replace <user>, <password>, and keep the /radiusx DB name
# ----------------------------------------------------------------
MONGO_URI=mongodb+srv://radiusx:radiusX@cluster0.1t9qnqg.mongodb.net/?appName=Cluster0


# ----------------------------------------------------------------
